{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "tags": ["-lintignore"],
  "entry": [
    "sentry.*.config.ts",
    ".storybook/**/*.{ts,tsx,js,jsx}",
    "scripts/**/*.{ts,tsx,js,jsx,mjs,cjs}",
    "src/i18nConfig.ts",
    "public/scripts/**/*.{ts,tsx,js,jsx}",
    "check-memory.mjs"
  ],
  "ignore": [
    "public/**",
    "src/locales/nouveautes/**",
    "scripts/**",
    "src/constants/ab-test.ts",
    "e2e/**"
  ],
  "ignoreDependencies": [
    "@axe-core/playwright",
    "i18next-parser",
    "yaml-loader",
    "playwright-core",
    "react-tooltip",
    "eslint-plugin-react-hooks"
  ],
  "ignoreBinaries": ["only-allow"]
}
