{
  "extends": ["../../tsconfig.json"],
  "compilerOptions": {
    "lib": ["es2024", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator"],
    "target": "es2022",
    "checkJs": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "incremental": true
  },
  "include": ["./**/*"],
  "exclude": ["node_modules", "dist", "coverage"]
}
