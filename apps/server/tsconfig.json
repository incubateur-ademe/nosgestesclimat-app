{
  "extends": ["../../tsconfig.json"],
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "checkJs": true,
    "types": ["node"],
    "incremental": true
  },
  "include": ["./**/*"],
  "exclude": ["node_modules", "dist", "coverage"]
}
