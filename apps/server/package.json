{
  "name": "@nosgestesclimat/server",
  "version": "3.0.2",
  "description": "The server part of the website nosgestesclimat.fr",
  "main": "./dist/index.js",
  "type": "module",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "prebuild": "pnpm clean",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist/*",
    "db:doc": "./prisma/docs/generate-doc.sh",
    "db:migrate": "ngc db:migrate",
    "db:post-migrate": "node ./dist/prisma/index.js",
    "dev": "NODE_ENV=development tsx --watch ./src ./src/index.ts",
    "dev:worker": "NODE_ENV=development tsx --watch ./src ./src/worker.ts",
    "format": "prettier --write \"**/*.{js,ts,md,json}\"",
    "jobs:computePollStats": "node dist/src/jobs/compute-poll-stats.js",
    "jobs:recoverMatomoStats": "node dist/src/jobs/recover-matomo-stats.js",
    "jobs:recoverNewsletterStats": "node dist/src/jobs/recover-newsletter-stats.js",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint",
    "typecheck": "tsc --noEmit",
    "start": "NODE_OPTIONS=--max-old-space-size=8192 node ./dist/src/index.js",
    "start:worker": "NODE_OPTIONS=--max-old-space-size=8192 node ./dist/src/worker.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "scalingo:remove-unused-dependencies": "pnpm --filter=@nosgestesclimat/server --prod deploy /tmp/deploy && rm -rf node_modules ../../node_modules && mv -f /tmp/deploy/node_modules .",
    "scalingo-postbuild": "cat /tmp/core-postinstall.log 2>/dev/null; pnpm run build && pnpm run scalingo:remove-unused-dependencies"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "@incubateur-ademe/nosgestesclimat": "4.10.5",
    "@nosgestesclimat/core": "workspace:*",
    "@publicodes/tools": "^1.8.0",
    "@sentry/node": "^10.47.0",
    "@ts-rest/core": "^3.53.0-rc.1",
    "@ts-rest/express": "^3.53.0-rc.1",
    "@ts-rest/open-api": "^3.53.0-rc.1",
    "axios": "^1.14.0",
    "axios-retry": "^4.5.0",
    "change-case": "^5.4.4",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.0",
    "express": "^4.22.1",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3",
    "publicodes": "^1.10.1",
    "request-ip": "^3.3.0",
    "slugify": "^1.6.9",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-transport-sentry-node": "^3.0.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.3",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@faker-js/faker": "^10.4.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/papaparse": "^5.5.2",
    "@types/redis-mock": "^0.17.3",
    "@types/request-ip": "^0.0.41",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "^4.1.2",
    "msw": "^2.12.14",
    "pglite-prisma-adapter": "^0.6.1",
    "redis-mock": "^0.56.3",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
