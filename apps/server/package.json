{
  "name": "@nosgestesclimat/server",
  "version": "3.0.2",
  "description": "The server part of the website nosgestesclimat.fr",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "db:post-migrate": "node --experimental-strip-types ./prisma/index.ts",
    "db:migrate": "ngc-core-db-migrate",
    "dev": "NODE_ENV=development node --experimental-strip-types --watch ./src/index.ts",
    "dev:worker": "NODE_ENV=development node --experimental-strip-types --watch ./src/worker.ts",
    "format": "prettier --write \"**/*.{js,ts,md,json}\"",
    "jobs:computePollStats": "node --experimental-strip-types ./src/jobs/compute-poll-stats.ts",
    "jobs:recoverMatomoStats": "node --experimental-strip-types ./src/jobs/recover-matomo-stats.ts",
    "jobs:recoverNewsletterStats": "node --experimental-strip-types ./src/jobs/recover-newsletter-stats.ts",
    "jobs:syncBrevoContacts": "node --experimental-strip-types ./src/jobs/sync-brevo-contacts.ts",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint",
    "typecheck": "tsc --noEmit",
    "start": "NODE_OPTIONS=--max-old-space-size=8192 node --experimental-strip-types ./src/index.ts",
    "start:worker": "NODE_OPTIONS=--max-old-space-size=8192 node --experimental-strip-types ./src/worker.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "postdeploy": "npm run db:migrate && npm run db:post-migrate && bash scripts/push-database-url-to-site.sh"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "@incubateur-ademe/nosgestesclimat": "4.12.4",
    "@nosgestesclimat/core": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@publicodes/tools": "^1.8.0",
    "@sentry/node": "^10.47.0",
    "@ts-rest/core": "^3.53.0-rc.1",
    "@ts-rest/express": "^3.53.0-rc.1",
    "@ts-rest/open-api": "^3.53.0-rc.1",
    "axios": "^1.14.0",
    "axios-retry": "^4.5.0",
    "change-case": "^5.4.4",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.0",
    "express": "^4.22.1",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3",
    "publicodes": "^1.10.1",
    "request-ip": "^3.3.0",
    "slugify": "^1.6.9",
    "swagger-ui-express": "^5.0.1",
    "valibot": "^1.4.0",
    "winston": "^3.19.0",
    "winston-transport-sentry-node": "^3.0.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.3",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@faker-js/faker": "^10.4.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/papaparse": "^5.5.2",
    "@types/redis-mock": "^0.17.3",
    "@types/request-ip": "^0.0.41",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "^4.1.2",
    "msw": "^2.12.14",
    "pglite-prisma-adapter": "^0.6.1",
    "redis-mock": "^0.56.3",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
