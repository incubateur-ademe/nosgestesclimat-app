{
  "extends": ["../../tsconfig.json"],
  "compilerOptions": {
    "lib": ["es2024", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator"],
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "incremental": true,
    "allowJs": true // ./bin files
  },
  "include": ["./**/*"],
  "exclude": ["node_modules"]
}
