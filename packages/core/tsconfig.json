{
  "extends": ["../../tsconfig.json"],
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "incremental": true
  },
  "include": [
    "src/**/*.ts",
    "prisma/seed.ts",
    "vitest.setup.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules"]
}
