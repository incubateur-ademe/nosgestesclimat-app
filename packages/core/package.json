{
  "name": "@nosgestesclimat/core",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "ngc-core-db-migrate": "./bin/db-migrate.js"
  },
  "files": [
    "dist",
    "prisma",
    "prisma.config.js",
    "bin"
  ],
  "scripts": {
    "prepare": "pnpm generate && pnpm build",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint",
    "format": "prettier --write ./**/*.{js,ts,tsx,json,md}",
    "typecheck": "tsc --noEmit",
    "generate": "pnpm db:generate",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "node --env-file .env --experimental-strip-types prisma/seed.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "prisma": {
    "seed": "node --env-file .env --experimental-strip-types prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a",
  "dependencies": {
    "@incubateur-ademe/nosgestesclimat": "https://pkg.pr.new/@incubateur-ademe/nosgestesclimat@2762",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.48.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "publicodes": "^1.10.1",
    "schema-dts": "^2.0.0",
    "valibot": "^1.4.0",
    "vitest": "^4.1.4"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@faker-js/faker": "^10.4.0",
    "fishery": "^2.4.0",
    "pglite-prisma-adapter": "^0.6.1",
    "typescript": "^5.9.3"
  }
}
