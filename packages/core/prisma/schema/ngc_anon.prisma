view AnonSimulation {
  id              String              @unique @db.Uuid
  date            DateTime
  progression     Float               @db.Real
  model           String
  computedResults Json
  actionChoices   Json
  situation       Json
  foldedSteps     Json[]
  userId          String              @db.Uuid
  user            AnonUser            @relation(fields: [userId], references: [id])
  userEmail       String?
  polls           AnonSimulationPoll[]
  createdAt       DateTime
  updatedAt       DateTime

  @@map("Simulation")
  @@schema("ngc_anon")
}

view AnonUser {
  id            String             @unique @db.Uuid
  ageRange      AgeRange?
  createdAt     DateTime
  updatedAt     DateTime
  simulations   AnonSimulation[]
  verifiedUsers AnonVerifiedUser[]

  @@map("User")
  @@schema("ngc_anon")
}

view AnonVerifiedUser {
  id                       String   @unique
  user_id                  String   @db.Uuid
  user                     AnonUser @relation(fields: [user_id], references: [id])
  name                     String?
  telephone                String?
  position                 String?
  optedInForCommunications Boolean
  createdAt                DateTime
  updatedAt                DateTime

  @@map("VerifiedUser")
  @@schema("ngc_anon")
}

view AnonOrganisation {
  id                    String                          @unique
  name                  String
  slug                  String
  type                  OrganisationType
  numberOfCollaborators Int?
  createdAt             DateTime
  updatedAt             DateTime
  anonPolls             AnonPoll[]
  administrators        AnonOrganisationAdministrator[]

  @@map("Organisation")
  @@schema("ngc_anon")
}

view AnonOrganisationAdministrator {
  id             String           @unique
  userEmail      String
  organisationId String
  organisation   AnonOrganisation @relation(fields: [organisationId], references: [id])
  createdAt      DateTime
  updatedAt      DateTime

  @@map("OrganisationAdministrator")
  @@schema("ngc_anon")
}

view AnonPoll {
  id                           String              @unique
  name                         String
  slug                         String              @unique
  funFacts                     Json?
  computedResults              Json?
  expectedNumberOfParticipants Int?
  customAdditionalQuestions    Json
  computeRealTimeStats         Boolean
  organisationId               String
  organisation                 AnonOrganisation    @relation(fields: [organisationId], references: [id])
  simulations                  AnonSimulationPoll[]
  createdAt                    DateTime
  updatedAt                    DateTime
  pollMode                     PollMode

  @@map("Poll")
  @@schema("ngc_anon")
}

view AnonSimulationPoll {
  id           String        @unique @db.Uuid
  pollId       String
  poll         AnonPoll      @relation(fields: [pollId], references: [id])
  simulationId String        @db.Uuid
  simulation   AnonSimulation @relation(fields: [simulationId], references: [id])
  createdAt    DateTime
  updatedAt    DateTime

  @@map("SimulationPoll")
  @@schema("ngc_anon")
}
