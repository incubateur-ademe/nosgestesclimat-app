model Action {
  id           String              @id @default(uuid()) @db.Uuid
  trackingId   String
  ruleId       String              @db.Uuid
  themeId      String              @db.Uuid
  translations ActionTranslation[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  publishedAt  DateTime?
  deletedAt    DateTime?
  assessments  ActionAssessment[]

  @@index([deletedAt, publishedAt])
  @@schema("ngc")
}

model ActionTranslation {
  id       String @id @default(uuid()) @db.Uuid
  action   Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  actionId String @db.Uuid
  locale   String

  title               String
  slug                String
  longDescription     String
  media               Json?
  tips                String?
  financialIncentives String?
  furtherExplore      String?
  seoMetadata         SeoMetadata?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([actionId, locale])
  @@unique([locale, slug])
  @@index([slug])
  @@schema("ngc")
}

model ActionAssessment {
  id           String     @id @default(uuid()) @db.Uuid
  simulation   Simulation @relation(fields: [simulationId], references: [id])
  action       Action     @relation(fields: [actionId], references: [id])
  impact       Float?
  applicable   Boolean?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  simulationId String     @db.Uuid
  actionId     String     @db.Uuid

  @@unique([simulationId, actionId])
  @@schema("ngc")
}

model SimulationComputation {
  simulationId String            @id @db.Uuid
  simulation   Simulation        @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  status       ComputationStatus @default(pending)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status, createdAt])
  @@schema("ngc")
}

enum ComputationStatus {
  pending
  processing
  completed
  failed

  @@schema("ngc")
}
